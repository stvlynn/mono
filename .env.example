# Optional bootstrap values for the containerized mono runtime.
# Copy to .env and fill with your real values when needed.

MONO_API_KEY=
# Supported providers: openai | openrouter | anthropic | google | gemini
MONO_BOOTSTRAP_PROVIDER=openai
MONO_BOOTSTRAP_MODEL=gpt-4.1-mini
MONO_BOOTSTRAP_BASE_URL=https://api.openai.com/v1
MONO_BOOTSTRAP_PROFILE=default
MONO_BOOTSTRAP_ALWAYS=0

# Optional Telegram bootstrap for channel control
MONO_TELEGRAM_ENABLED=0
MONO_TELEGRAM_BOT_TOKEN=
MONO_TELEGRAM_BOT_ID=
MONO_TELEGRAM_DM_POLICY=pairing
